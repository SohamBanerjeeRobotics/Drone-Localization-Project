WorldInfo {
  info [
    "Bitcraze's Crazyflie drone."
    "This simulation allows you to pilot the drone with your keyboard."
  ]
  title "Crazyflie"
  # basicTimeStep 9.5
}
Viewpoint {
  orientation -0.10311089632172073 0.641740519713268 0.7599587149430397 0.6949228976889259
  position -1.4079821323259103 -0.8990534316278701 0.7779322600533379
  follow "Crazyflie"
}
TexturedBackground {
}
TexturedBackgroundLight {
}
Floor {
}
Crazyflie {
  translation 0.0 0.0 0.0
  controller "<extern>"
}
Solid {
  name "SingleRoomModel"
  translation 0.0 0.0 0.0      # position in world
  rotation 0 1 0 0       # orientation (axis-angle)
  children [
    Transform {
      scale 0.001 0.001 0.001
      children [
        Shape {
          appearance PBRAppearance {
          baseColor 0.7 0.7 0.7
          roughness 0.5
          metalness 0
          }
          geometry Mesh {
            url [
              "SingleRoomModel.stl"
            ]
          }
        }
      ]
    }
  ]
}
